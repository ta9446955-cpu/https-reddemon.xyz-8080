<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="plugin.video.reddemon" name="Reddemon" version="1.0.1" provider-name="Reddemon">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests" version="2.25.1"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Watch your YouTube playlists in Kodi</summary>
            <description lang="en_GB">Sign in with your YouTube account and browse your own playlists directly in Kodi. Playback is handled by the official YouTube addon.</description>
            <platform>all</platform>
            <license>GPL-2.0</license>
            <source>https://github.com/ta9446955-cpu/https-reddemon.xyz-8080</source>
        </extension>
    </addon>
    <addon id="repository.reddemon" name="Reddemon Repository" version="1.0.1" provider-name="Reddemon">
        <extension point="xbmc.addon.repository" name="Reddemon Repository">
            <dir>
                <info compressed="false">https://raw.githubusercontent.com/ta9446955-cpu/https-reddemon.xyz-8080/main/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/ta9446955-cpu/https-reddemon.xyz-8080/main/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/ta9446955-cpu/https-reddemon.xyz-8080/main/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Reddemon Repository</summary>
            <description lang="en_GB">Official repository for the Reddemon YouTube playlist addon.</description>
            <platform>all</platform>
            <license>GPL-2.0</license>
        </extension>
    </addon>
</addons>
